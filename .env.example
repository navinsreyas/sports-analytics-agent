# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# Groq API key — https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Neon PostgreSQL connection string — https://neon.tech
NEON_DB_URL=postgresql://user:password@host/dbname?sslmode=require

# Neo4j password (local Neo4j Desktop instance)
NEO4J_PASSWORD=your_neo4j_password_here

# Gemini API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Football-Data.org API key — https://www.football-data.org
FOOTBALL_API_KEY=your_football_api_key_here
